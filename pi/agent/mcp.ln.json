{
  "mcpServers": {
    "playwright": {
      "command": "playwright-mcp",
      "args": [],
      "lifecycle": "lazy"
    },
    "chrome": {
      "command": "playwright-mcp",
      "args": ["--extension"],
      "env": { "PLAYWRIGHT_MCP_EXTENSION_TOKEN": "${PLAYWRIGHT_MCP_EXTENSION_TOKEN}" },
      "lifecycle": "lazy"
    },
    "neovim": {
      "command": "mcp-neovim-server",
      "args": ["--socket", "/tmp/nvim"],
      "lifecycle": "lazy"
    },
    "tavily": {
      "command": "tavily-mcp",
      "args": [],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      },
      "lifecycle": "lazy"
    },
    "slack": {
      "command": "/Users/davidsu/.claude/scripts/slack-mcp.sh",
      "args": [],
      "lifecycle": "lazy"
    }
  }
}
