#!/usr/bin/env bash
# teamup-hook — wire teamup into a harness lifecycle so an agent can't forget the
# channel. Reads the hook's JSON event on stdin, finds the channels THIS session
# joined — matched by the session GUID (`.session_id`) when the harness provides
# one, else by cwd — and acts per event:
#
#   stop         block the stop (exit 2) while any joined channel has unread
#                messages (agent must `recv`) OR has no live background `wait`
#                listener (agent must arm one so it stays reachable while idle —
#                the "claude fell asleep in the channel" failure). Both conditions
#                clear on the agent's next action, so the hook still can't loop.
#   session-end  `leave` every channel this session joined, so rosters stay honest.
#
# It must never wedge the agent on its own failure: any missing input, missing
# tool, or empty registry exits 0 (fail-open, stop allowed).
#
# Claude Code wiring (~/.claude/settings.json):
#   "Stop":       command "~/.claude/skills/suss-teamup/scripts/teamup-hook stop"
#   "SessionEnd": command "~/.claude/skills/suss-teamup/scripts/teamup-hook session-end"

set -uo pipefail

readonly EVENT="${1:-}"
# The no-live-listener block (b, below) is OPT-IN via --require-listener: it only
# fits a harness whose agent can launch a persistent background `wait` (claude-code
# via run_in_background). Harnesses with their own idle watcher (pi's fs.watch) or
# no background-bash MUST NOT pass it — they stay reachable their own way.
require_listener=false; [ "${2:-}" = "--require-listener" ] && require_listener=true
readonly HERE="$(cd "$(dirname "$0")" && pwd)"
readonly TEAMUP="$HERE/teamup"
readonly BASE="${SUSS_TEAMUP_DIR:-/tmp/suss-teamup}"
readonly SESSIONS="$BASE/.sessions.tsv"

[ -f "$SESSIONS" ] || exit 0
input="$(cat)"
cwd="$(printf '%s' "$input" | jq -r '.cwd // empty' 2>/dev/null || true)"
sid="$(printf '%s' "$input" | jq -r '.session_id // empty' 2>/dev/null || true)"
[ -n "$cwd" ] || [ -n "$sid" ] || exit 0

# Find this session's channels, snapshotting up front (session-end rewrites
# $SESSIONS as it leaves). Prefer the session GUID — collision-free even when two
# agents share a cwd. Fall back to cwd only for harnesses whose `join` can't stamp
# a GUID (their rows carry an empty GUID field, so a cwd match never grabs another
# harness's GUID-keyed row in the same directory).
if [ -n "$sid" ]; then
  my_channels="$(awk -F'\t' -v sid="$sid" '$4==sid{print $2"\t"$3}' "$SESSIONS")"
else
  my_channels="$(awk -F'\t' -v c="$cwd" '$1==c && $4==""{print $2"\t"$3}' "$SESSIONS")"
fi
[ -n "$my_channels" ] || exit 0

case "$EVENT" in
  stop)
    # Per joined channel, block on either (both cleared by one agent action -> no loop):
    #   (a) UNREAD messages          -> `recv` clears them. (Always on.)
    #   (b) no live `wait` listener  -> arm a background `wait --timeout 0`. OPT-IN
    #       (--require-listener) and claude-code-ONLY: it assumes the agent can launch
    #       a persistent background wait. pi keeps itself reachable via its extension's
    #       fs.watch watcher (no teamup-wait process), so pi MUST NOT pass the flag —
    #       else it gets told to arm a wait it can't run and doesn't need.
    # (b)'s liveness marker is the wait's pidfile (.wait.{handle}) + kill -0, NOT a
    # pgrep match — so a prefix handle / editor showing channel.tsv / regex metachar
    # can't false-positive, and a killed wait (stale pidfile) reads as "no listener".
    blocked=""
    while IFS=$'\t' read -r subject handle; do
      [ -n "$subject" ] || continue
      summary="$("$TEAMUP" status "$subject" --as "$handle" 2>/dev/null)"
      unread="${summary#*unread=}"; unread="${unread%% *}"
      if [ "${unread:-0}" != "0" ]; then
        action="teamup recv $subject --as $handle"
        case "$summary" in
          *asks_for_me=0*) : ;;
          *) action="$action, then answer the ask aimed at you (say/ack)" ;;
        esac
        blocked+="  [$subject] $summary — $action"$'\n'
      elif [ "$require_listener" = true ]; then
        pidf="$BASE/$subject/.wait.$handle"
        if ! { [ -f "$pidf" ] && kill -0 "$(cat "$pidf" 2>/dev/null)" 2>/dev/null; }; then
          blocked+="  [$subject] no live listener — stay reachable while idle by running this in the BACKGROUND: $TEAMUP wait $subject --as $handle --timeout 0"$'\n'
        fi
      fi
    done <<< "$my_channels"
    [ -n "$blocked" ] || exit 0
    printf 'teamup: do not go idle yet — clear these first:\n%s' "$blocked" >&2
    exit 2
    ;;

  session-end)
    while IFS=$'\t' read -r subject handle; do
      [ -n "$subject" ] || continue
      "$TEAMUP" leave "$subject" --as "$handle" >/dev/null 2>&1 || true
    done <<< "$my_channels"
    ;;
esac
exit 0
