#!/usr/bin/env bash
# teamup — a tiny file-based message channel so two or more agents can coordinate.
#
# Storage (no daemon, no deps):
#   $SUSS_TEAMUP_DIR/{subject}/
#     channel.tsv          append-only log: ts \t from \t type \t body   (one line/msg)
#     members/{handle}     presence file: pwd / doing / joined
#     .cursor.{handle}     last line number this handle has read
#
# Each message has a stable id = its 1-based line number in channel.tsv ("seq").
# recv/peek/wait/join print it as "#<seq>" so any agent can ack a specific
# message by id. Message types: ping (join/leave noise), say (chatter),
# ask (a question targeted with @handle), ack (clears a pending ask), bye.
#
# Identity is explicit and stateless: pass --as {handle} on every call.
# Appends are atomic (O_APPEND); presence is one file per handle — no lock needed.
#
# Output is a plain mailbox protocol any agent (Codex/Gemini/Claude) can read:
# key=value summary lines and "#seq [time] handle (type) body" message lines.
#
# KNOWN ISSUE — "agents forget they're on a channel" (2026-06-22)
#   Symptom: an agent joins, goes heads-down on its own work, and never sees
#   peers' later messages. Peer messages pile up unread; rosters go stale because
#   agents stop without saying `bye`. Root cause is NOT the poll interval — it's
#   the WAKE LIFECYCLE: the only listener is a `wait` an agent launches in the
#   background, it used to die after 110s, and it had to be manually re-armed
#   (which agents drop). A finished background command also only re-invokes the
#   agent BETWEEN turns — it can't interrupt a turn in progress.
#
#   Script-only mitigation taken here (best-effort, may not fully solve it):
#     - `wait --timeout 0` blocks indefinitely, so one armed background watcher
#       survives a whole work-turn and reliably re-invokes the agent on the next
#       real message instead of dying on a timer.
#     - When `fswatch` is present it replaces the busy `sleep 2` poll, so a
#       long-lived watcher costs nothing until the channel actually changes.
#   Durable fix (implemented for claude-code) — `scripts/teamup-hook`:
#     - join/leave persist a cwd -> (subject, handle) map in $BASE/.sessions.tsv
#       (a Stop hook only learns the session's cwd, never the handle).
#     - `teamup-hook stop` blocks the stop (exit 2) while any of this cwd's
#       channels has UNREAD messages, forcing a `recv` before the agent yields.
#       It blocks on unread only — `recv` always clears unread, so it can't loop;
#       an unanswered-but-read ask does not re-block (that would trap a session).
#     - `teamup-hook session-end` auto-`leave`s this cwd's channels.
#   Wire it per harness. claude-code: ~/.claude/settings.json Stop + SessionEnd.
#   Other harnesses (e.g. pi) need their own wiring; the script is harness-neutral
#   as long as the lifecycle event delivers the session cwd as JSON `.cwd` on stdin.

set -eo pipefail

readonly BASE="${SUSS_TEAMUP_DIR:-/tmp/suss-teamup}"
readonly DEFAULT_WAIT=110   # seconds; stays under the default 120s Bash budget

die() { echo "teamup: $*" >&2; exit 1; }

usage() {
  cat >&2 <<'EOF'
usage:
  teamup join   <subject> --as <handle> [--pwd <path>] [--doing <text>]
  teamup say    <subject> --as <handle> <message...>      (alias: send)
  teamup ask    <subject> --as <handle> [--to <handle>] <question...>  # a question that needs an answer
  teamup ack    <subject> --as <handle> [--re <seq>] [note...]         # answer/clear an ask (default: latest peer msg)
  teamup recv   <subject> --as <handle>                   # new msgs from others + summary line, non-blocking
  teamup status <subject> --as <handle>                   # summary only; exit 0=clean 1=unread 2=ask-for-me (cursor untouched)
  teamup status --as <handle>                             # no subject: list every team this handle is on + member count
  teamup wait   <subject> --as <handle> [--timeout <sec>] # block until someone speaks (default 110s; 0 = forever, for background idle waits)
  teamup roster <subject>                                 # who is on the channel
  teamup peek   <subject> [--last <n>]                    # show recent history (default 20)
  teamup leave  <subject> --as <handle>
  teamup leave  --all     --as <handle>                   # leave every channel this handle is on
  teamup erase  <subject> [--force]                       # delete a channel + its registry rows (refuses if members remain unless --force)
  teamup channels                                         # list active subjects
EOF
  exit 2
}

now()   { date -u +%Y-%m-%dT%H:%M:%SZ; }
chan()  { printf '%s/%s/channel.tsv' "$BASE" "$1"; }
mdir()  { printf '%s/%s/members' "$BASE" "$1"; }
cursor(){ printf '%s/%s/.cursor.%s' "$BASE" "$1" "$2"; }

# A map so a lifecycle hook can find which channels THIS session joined. One TSV
# row per join: cwd \t subject \t handle \t session_guid. The hook keys on the
# session GUID — collision-free even when several agents share a cwd. The GUID
# comes from $TEAMUP_SESSION (a harness wrapper, e.g. the pi extension, sets it)
# or $CLAUDE_CODE_SESSION_ID (claude-code sets it natively); empty if neither,
# in which case the hook falls back to cwd. Concurrent join/leave races are "last
# writer wins" — a lost row only skips that channel until the next re-join.
sessions_file() { printf '%s/.sessions.tsv' "$BASE"; }

register_session() { # subject handle pwd
  local file sid; file="$(sessions_file)"; sid="${TEAMUP_SESSION:-${CLAUDE_CODE_SESSION_ID:-}}"; mkdir -p "$BASE"
  if [ -f "$file" ]; then
    awk -F'\t' -v p="$3" -v s="$1" -v h="$2" '!($1==p && $2==s && $3==h)' \
      "$file" > "$file.tmp" && mv "$file.tmp" "$file"
  fi
  printf '%s\t%s\t%s\t%s\n' "$3" "$1" "$2" "$sid" >> "$file"
}

unregister_session() { # subject handle
  local file; file="$(sessions_file)"; [ -f "$file" ] || return 0
  awk -F'\t' -v s="$1" -v h="$2" '!($2==s && $3==h)' "$file" > "$file.tmp" && mv "$file.tmp" "$file"
}

unregister_handle() { # handle
  local file; file="$(sessions_file)"; [ -f "$file" ] || return 0
  awk -F'\t' -v h="$1" '$3!=h' "$file" > "$file.tmp" && mv "$file.tmp" "$file"
}

# Collapse a message to a single safe TSV line (tabs/newlines -> spaces).
oneline() { printf '%s' "$*" | tr '\t\n\r' '   '; }

append() { # subject from type body
  local subject=$1 from=$2 type=$3 body=$4
  mkdir -p "$(dirname "$(chan "$subject")")"
  printf '%s\t%s\t%s\t%s\n' "$(now)" "$from" "$type" "$(oneline "$body")" >> "$(chan "$subject")"
}

linecount() { [ -f "$1" ] && wc -l < "$1" | tr -d ' ' || echo 0; }

# Stamp every message with its stable id (seq = 1-based line number):
# "seq <TAB> ts <TAB> from <TAB> type <TAB> body". Empty if the channel is new.
numbered() { # subject
  local file; file="$(chan "$1")"
  [ -f "$file" ] || return 0
  awk -F'\t' '{ printf "%d\t%s\n", NR, $0 }' "$file"
}

# Pretty-print numbered lines from stdin: "#seq [time] handle (type) body"
pretty() {
  awk -F'\t' '{
    split($2, stamp, "T"); clock = substr(stamp[2], 1, 8)
    printf "  #%s [%s] %s (%s) %s\n", $1, clock, $3, $4, $5
  }'
}

# Messages from others since this handle's cursor, seq-stamped. Empty if none.
fresh_lines() { # subject handle
  local cur; cur="$(cat "$(cursor "$1" "$2")" 2>/dev/null || echo 0)"
  # c+0 coerces the cursor numeric: an empty/garbage cursor file (interrupted
  # write) would otherwise make "$1 > c" a string compare and flag everything.
  numbered "$1" | awk -F'\t' -v c="$cur" -v me="$2" '$1 > c+0 && $3!=me'
}

# Highest seq of a message not from this handle (empty if none).
latest_peer_seq() { # subject handle
  numbered "$1" | awk -F'\t' -v me="$2" '$3!=me{seq=$1} END{if(seq) print seq}'
}

# Count asks aimed at this handle (@handle) that it has not yet answered. Any
# later message from the handle — an `ack`, a `say`, anything — clears the ask,
# so prose answers count and there is no ack-parsing policy to drift out of sync.
pending_asks_for_me() { # subject handle
  numbered "$1" | awk -F'\t' -v me="$2" '
    $3==me { answered_through=$1 }
    $4=="ask" && $3!=me && index($5, "@" me) { asked[$1]=1 }
    END { n=0; for (seq in asked) if (seq+0 > answered_through+0) n++; print n+0 }
  '
}

# Block until the channel changes, then return so the caller re-checks. fswatch
# wakes only on a real change (free for an indefinite watcher); sleep is the
# universal fallback and is fine for short bounded waits.
block_for_change() { # channel-file
  if [ -f "$1" ] && command -v fswatch >/dev/null 2>&1; then
    fswatch -1 "$1" >/dev/null 2>&1 || sleep 2
  else
    sleep 2
  fi
}

require_handle() { [ -n "${HANDLE:-}" ] || die "missing --as <handle>"; }

# ---- arg parsing --------------------------------------------------------------
CMD="${1:-}"; shift || usage
SUBJECT=""; HANDLE=""; PWD_ARG="$PWD"; DOING=""; TIMEOUT="$DEFAULT_WAIT"; LAST=20; ALL=false; FORCE=false
TO=""; RE=""
MSG=()
while [ $# -gt 0 ]; do
  case "$1" in
    --as)      HANDLE="$2"; shift 2 ;;
    --pwd)     PWD_ARG="$2"; shift 2 ;;
    --doing)   DOING="$2"; shift 2 ;;
    --timeout) TIMEOUT="$2"; shift 2 ;;
    --last)    LAST="$2"; shift 2 ;;
    --to)      TO="$2"; shift 2 ;;
    --re)      RE="$2"; shift 2 ;;
    --all)     ALL=true; shift ;;
    --force)   FORCE=true; shift ;;
    --) shift; MSG+=("$@"); break ;;
    -*) die "unknown flag: $1 (put free-form message text after -- )" ;;
    *) if [ -z "$SUBJECT" ]; then SUBJECT="$1"; else MSG+=("$1"); fi; shift ;;
  esac
done

# ---- commands -----------------------------------------------------------------
case "$CMD" in
  join)
    [ -n "$SUBJECT" ] || usage; require_handle
    mkdir -p "$(mdir "$SUBJECT")"
    sid="${TEAMUP_SESSION:-${CLAUDE_CODE_SESSION_ID:-}}"
    member="$(mdir "$SUBJECT")/$HANDLE"
    # A handle owns one cursor file (.cursor.$HANDLE); two live sessions sharing a
    # handle would race it and silently drop/re-show messages. Refuse if the handle
    # is already held by a DIFFERENT session. Same session re-joining (e.g. after a
    # resume — getSessionId is stable) keeps its GUID, so it's allowed.
    if [ -f "$member" ]; then
      held="$(sed -n 's/^session=//p' "$member")"
      [ -z "$sid" ] || [ -z "$held" ] || [ "$held" = "$sid" ] || \
        die "handle '$HANDLE' is already on '$SUBJECT' from another session — pick a different handle"
    fi
    printf 'pwd=%s\ndoing=%s\njoined=%s\nsession=%s\n' "$PWD_ARG" "$(oneline "$DOING")" "$(now)" "$sid" \
      > "$member"
    append "$SUBJECT" "$HANDLE" ping "joined — doing: ${DOING:-?} @ $PWD_ARG"
    register_session "$SUBJECT" "$HANDLE" "$PWD_ARG"
    # Cursor to end so future recv only shows what comes next.
    printf '%s' "$(linecount "$(chan "$SUBJECT")")" > "$(cursor "$SUBJECT" "$HANDLE")"
    echo "joined '$SUBJECT' as '$HANDLE'."
    echo "--- on channel now ---"
    "$0" roster "$SUBJECT"
    echo "--- recent ---"
    "$0" peek "$SUBJECT" --last "$LAST"
    ;;

  say|send)
    [ -n "$SUBJECT" ] || usage; require_handle
    if [ ${#MSG[@]} -gt 0 ]; then text="${MSG[*]}"; else text="$(cat)"; fi
    [ -n "$text" ] || die "nothing to say"
    append "$SUBJECT" "$HANDLE" say "$text"
    echo "sent."
    ;;

  recv)
    [ -n "$SUBJECT" ] || usage; require_handle
    fresh="$(fresh_lines "$SUBJECT" "$HANDLE")"
    printf '%s' "$(linecount "$(chan "$SUBJECT")")" > "$(cursor "$SUBJECT" "$HANDLE")"
    unread="$(printf '%s' "$fresh" | awk 'END{print NR+0}')"
    pending="$(pending_asks_for_me "$SUBJECT" "$HANDLE")"
    senders="$(printf '%s' "$fresh" | awk -F'\t' 'NF{print $3}' | sort -u | paste -sd, -)"
    printf 'summary: unread=%s asks_for_me=%s from=%s\n' "$unread" "$pending" "${senders:-none}"
    if [ -n "$fresh" ]; then printf '%s\n' "$fresh" | pretty; else echo "  (nothing new)"; fi
    ;;

  ask)
    [ -n "$SUBJECT" ] || usage; require_handle
    if [ ${#MSG[@]} -gt 0 ]; then text="${MSG[*]}"; else text="$(cat)"; fi
    [ -n "$text" ] || die "nothing to ask"
    [ -n "$TO" ] && text="@$TO $text"
    append "$SUBJECT" "$HANDLE" ask "$text"
    echo "asked${TO:+ @$TO}."
    ;;

  ack)
    [ -n "$SUBJECT" ] || usage; require_handle
    seq="$RE"; [ -n "$seq" ] || seq="$(latest_peer_seq "$SUBJECT" "$HANDLE")"
    [ -n "$seq" ] || die "nothing to ack — no peer messages yet"
    note="${MSG[*]}"
    append "$SUBJECT" "$HANDLE" ack "re:#$seq${note:+ $note}"
    echo "acked #$seq."
    ;;

  status)
    require_handle
    # No subject -> my-teams overview: every channel where I'm a member, with its
    # roster size (a crashed session that never left inflates the count, same
    # staleness caveat as `channels`). With a subject -> the per-channel unread/ask
    # surface the hook keys on (exit 0/1/2, cursor untouched).
    if [ -z "$SUBJECT" ]; then
      on_any=false
      if [ -d "$BASE" ]; then
        for sd in "$BASE"/*/; do
          [ -d "$sd" ] || continue
          s="$(basename "$sd")"
          [ -f "$(mdir "$s")/$HANDLE" ] || continue
          n="$(ls -A "$(mdir "$s")" 2>/dev/null | wc -l | tr -d ' ')"
          printf '  %s — %s member(s)\n' "$s" "$n"
          on_any=true
        done
      fi
      [ "$on_any" = true ] || echo "  (on no teams)"
      exit 0
    fi
    unread="$(fresh_lines "$SUBJECT" "$HANDLE" | awk 'END{print NR+0}')"
    pending="$(pending_asks_for_me "$SUBJECT" "$HANDLE")"
    printf 'summary: unread=%s asks_for_me=%s\n' "$unread" "$pending"
    [ "$pending" -gt 0 ] && exit 2
    [ "$unread" -gt 0 ] && exit 1
    exit 0
    ;;

  wait)
    [ -n "$SUBJECT" ] || usage; require_handle
    file="$(chan "$SUBJECT")"
    [ "$TIMEOUT" -gt 0 ] && deadline=$(( $(date +%s) + TIMEOUT )) || deadline=0
    while :; do
      fresh="$(fresh_lines "$SUBJECT" "$HANDLE")"
      if [ -n "$fresh" ]; then
        printf '%s' "$(linecount "$file")" > "$(cursor "$SUBJECT" "$HANDLE")"
        printf '%s\n' "$fresh" | pretty
        exit 0
      fi
      [ "$deadline" -ne 0 ] && [ "$(date +%s)" -ge "$deadline" ] && { echo "  (timeout — no one spoke)"; exit 1; }
      block_for_change "$file"
    done
    ;;

  roster)
    [ -n "$SUBJECT" ] || usage
    d="$(mdir "$SUBJECT")"
    [ -d "$d" ] && [ -n "$(ls -A "$d" 2>/dev/null)" ] || { echo "  (no members)"; exit 0; }
    for f in "$d"/*; do
      h="$(basename "$f")"
      p="$(sed -n 's/^pwd=//p' "$f")"; do="$(sed -n 's/^doing=//p' "$f")"
      printf '  %s — %s @ %s\n' "$h" "${do:-?}" "${p:-?}"
    done
    ;;

  peek)
    [ -n "$SUBJECT" ] || usage
    recent="$(numbered "$SUBJECT" | tail -n "$LAST")"
    [ -n "$recent" ] || { echo "  (channel empty)"; exit 0; }
    printf '%s\n' "$recent" | pretty
    ;;

  leave)
    require_handle
    if [ "$ALL" = true ]; then
      [ -d "$BASE" ] || { echo "no channels."; exit 0; }
      for sd in "$BASE"/*/; do
        s="$(basename "$sd")"
        [ -f "$(mdir "$s")/$HANDLE" ] || continue
        append "$s" "$HANDLE" bye "left the channel"
        rm -f "$(mdir "$s")/$HANDLE" "$(cursor "$s" "$HANDLE")"
        echo "left '$s'."
      done
      unregister_handle "$HANDLE"
    else
      [ -n "$SUBJECT" ] || usage
      append "$SUBJECT" "$HANDLE" bye "left the channel"
      rm -f "$(mdir "$SUBJECT")/$HANDLE" "$(cursor "$SUBJECT" "$HANDLE")"
      unregister_session "$SUBJECT" "$HANDLE"
      echo "left '$SUBJECT'."
    fi
    ;;

  channels)
    [ -d "$BASE" ] || { echo "  (none)"; exit 0; }
    for sd in "$BASE"/*/; do
      [ -d "$sd" ] || continue
      s="$(basename "$sd")"
      n="$(ls -A "$(mdir "$s")" 2>/dev/null | wc -l | tr -d ' ')"
      printf '  %s — %s member(s)\n' "$s" "$n"
    done
    ;;

  # Delete a whole channel: scrub its session-registry rows (so no peer's
  # lifecycle hook resurrects it) and remove the dir. Refuses while any member
  # is still present — `leave` first, or pass --force to nuke regardless.
  erase|cleanup)
    [ -n "$SUBJECT" ] || usage
    [ -d "$BASE/$SUBJECT" ] || { echo "no channel '$SUBJECT' to erase."; exit 0; }
    members="$(ls -A "$(mdir "$SUBJECT")" 2>/dev/null)"
    if [ -n "$members" ] && [ "$FORCE" != true ]; then
      die "'$SUBJECT' still has members: $(printf '%s' "$members" | tr '\n' ' '). Leave first, or re-run with --force."
    fi
    if [ -f "$(sessions_file)" ]; then
      awk -F'\t' -v s="$SUBJECT" '$2 != s' "$(sessions_file)" > "$(sessions_file).tmp" \
        && mv "$(sessions_file).tmp" "$(sessions_file)"
    fi
    rm -rf "$BASE/$SUBJECT"
    echo "erased channel '$SUBJECT'."
    ;;

  *) usage ;;
esac
